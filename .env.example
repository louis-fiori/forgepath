# Copy to .env (gitignored) and fill in your fork's values. (scripts/_env.sh
# auto-creates .env from this file on first run if it's missing.)
#
# Three consumption paths:
#
#  1. Runtime substitution (read on every `make local-up` / `make backstage-reload`):
#       - platform/backstage/templates/**/template.yaml  (Backstage scaffolder)
#       - platform/argocd/bootstrap/root-app.yaml         (Argo CD root app)
#     These files keep ${FORGEPATH_*} placeholders in git; sed renders them in
#     scripts/backstage-sync.sh and scripts/local-up.sh before they're used.
#
#  2. One-shot rebrand (run `make configure` once after editing this file):
#       - gitops/apps/*.yaml
#     ArgoCD reads these straight from git, so placeholders can't survive there.
#     `make configure` does an in-place sed replace using the values below.
#     Idempotent: re-running with the same .env is a no-op.
#
#  3. Secret materialization (incident-analyzer settings, secrets AND non-secret
#     knobs alike): `make local-up` bakes the values below into the
#     `incident-analyzer/incident-analyzer-secrets` K8s Secret; the Deployment
#     reads every key as an optional env var. After editing .env on a running
#     cluster, re-sync with `make incident-analyzer-secrets`.
#
# NOT configured here (GitOps-owned, edit the manifest):
#   - incident-generator chaos tuning (EMIT_INTERVAL, ERROR_RATIO):
#     gitops/platform/incident-generator/deployment.yaml, table in
#     services/incident-generator/README.md
#   - in-cluster endpoints (LOKI_URL, PROMETHEUS_URL, BACKSTAGE_URL):
#     set in gitops/platform/incident-analyzer/deployment.yaml
#   - advanced analyzer thresholds (DETECT_WINDOW, PANIC_THRESHOLD,
#     REFILE_COOLDOWN_SECONDS, MAX_TOKENS, LLM_TIMEOUT_SECONDS, LLM_MAX_RETRIES):
#     not wired anywhere by default, the values come from
#     services/incident-analyzer/app/config.py. To change one, add it as an env
#     var on the Deployment (config reads it from the environment).

# GitHub login / org that owns the forgepath fork.
FORGEPATH_GITHUB_OWNER=louis-fiori

# Repo name (under the owner above).
FORGEPATH_GITHUB_REPO=forgepath

# Branch the scaffolder PRs target, and that ArgoCD's root app tracks.
FORGEPATH_TARGET_BRANCH=dev

# Kube context the helper scripts target (incident-analyzer-secrets re-sync,
# trigger-incident port-forward fallback). `kind-forgepath` for `make local-up`,
# `docker-desktop` for `make docker-up`.
FORGEPATH_KUBE_CONTEXT=kind-forgepath

# @backstage/create-app version pinned by `make backstage-init`. The overlay
# baseline (platform/backstage/overlay/upstream/) is authored against this
# exact generation, bump it deliberately, following "Upgrading the scaffold"
# in platform/backstage/overlay/README.md.
FORGEPATH_CREATE_APP_VERSION=0.8.3

# Fine-grained GitHub PAT scoped to the fork above:
#   - Contents: Read and write          (scaffolder writes the PR branch)
#   - Pull requests: Read and write     (open/close PRs)
#   - Issues: Read and write            (incident-analyzer files incident issues)
#   - Metadata: Read                    (mandatory, auto-added)
#
# scripts/local-up.sh reads this value and generates K8s Secrets from it:
# `backstage/backstage-github-token` (Backstage backend),
# `argocd/forgepath-repo-creds` (ArgoCD + pullRequest ApplicationSet), and it's
# also injected into `incident-analyzer/incident-analyzer-secrets` so the
# analyzer can open issues. No .local.yaml files to maintain.
GITHUB_TOKEN=

# --- AI Incident Analyzer (services/incident-analyzer) ---

# LLM provider: "bedrock" (Claude on Amazon Bedrock, AWS SigV4) or "anthropic"
# (direct Anthropic API key). Default is bedrock.
LLM_PROVIDER=bedrock

# Comma-separated namespaces the analyzer polls for incidents. Add your
# scaffolded preview namespaces (preview-scaffold-<name>) to watch them too.
WATCH_NAMESPACES=incident-generator

# Background poll cadence, in seconds.
POLL_INTERVAL_SECONDS=60

# Error log lines within the detection window that trip an incident.
ERROR_THRESHOLD=20

# Background auto-detection loop? true|false. Set false for MANUAL-ONLY: the
# analyzer then only runs when you trigger it (/analyze, or the Backstage
# "Analyze an incident" template), no background Claude calls, so no token
# spend on every error spike.
POLL_ENABLED=true

# Open a GitHub issue for each new incident? true|false. Also flippable at
# runtime (POST /analyze?…&open_issue=, POST /settings) and per-run from the
# Backstage "Analyze an incident" template.
ISSUES_ENABLED=true

# --- Bedrock path (LLM_PROVIDER=bedrock) ---
# Region where Claude is enabled in Bedrock (Model access).
AWS_REGION=us-east-1
# Model ID. The base ID (anthropic.claude-sonnet-4-6) is NOT invocable on-demand
#, you must use the region-scoped INFERENCE PROFILE: prefix by geo to match
# AWS_REGION → eu.* (eu-…), us.* (us-…), apac.* (ap-…). Confirm the exact ID with:
#   aws bedrock list-inference-profiles --region $AWS_REGION \
#     --query "inferenceProfileSummaries[?contains(inferenceProfileId,'sonnet-4-6')].inferenceProfileId"
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
# AWS auth, two modes, the access key takes precedence over the profile:
#
#  A) Named PROFILE (default). scripts/local-up.sh mounts your ~/.aws (config +
#     credentials) into the pod; AWS_PROFILE selects which profile to use
#     (static-key or assume-role; the profile needs bedrock:InvokeModel). Leave
#     the profile's creds in ~/.aws as usual. Empty ~/.aws + no access key below
#     → detection-only.
AWS_PROFILE=default
# Directory the ~/.aws mount is built from (config + credentials files).
# Leave empty for $HOME/.aws.
AWS_CONFIG_DIR=
#
#  B) Static ACCESS KEY. Set the pair below (+ session token for STS/temporary
#     creds) to authenticate without any ~/.aws mount, handy for CI or a
#     dedicated IAM user. When set, these win over AWS_PROFILE.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Only for temporary credentials (assume-role / SSO). Leave empty for a long-lived key.
AWS_SESSION_TOKEN=

# --- Direct Anthropic API path (LLM_PROVIDER=anthropic) ---
# Anthropic API key from console.anthropic.com. Empty → detection-only.
ANTHROPIC_API_KEY=
# Model for the direct-API path (plain Anthropic model ID, no region prefix).
ANALYZER_MODEL=claude-sonnet-4-6

# Redact sensitive data (emails, phone numbers, card numbers, IBANs, auth tokens,
# IPv4/IPv6 addresses, secret key/value pairs incl. JSON-quoted) from log samples
# & pod events before they're sent to the LLM?
# true|false. Best-effort, pattern-based; recommended on for a payments platform.
MASKING_ENABLED=true

# Optional. Shared service-to-service bearer token. Backstage accepts it for the
# notifications API (backend.auth.externalAccess); the incident-analyzer also
# requires it on /analyze, /analyze-log and /settings (the Backstage actions send
# it automatically). Leave blank to have scripts/local-up.sh generate a random one
# on first run and reuse it thereafter, blank also leaves those endpoints open.
BACKSTAGE_S2S_TOKEN=

# --- Host tooling (scripts/) ---

# Where scripts/trigger-incident.sh (`make incident`) reaches the generator
# from the host. When unreachable it falls back to an ephemeral port-forward
# against FORGEPATH_KUBE_CONTEXT.
INCIDENT_GEN_URL=http://localhost:8889
