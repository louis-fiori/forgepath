# Scaffolded Backstage app, generated by `make backstage-init`
local/backstage

# macOS
.DS_Store

# Env / secrets
.env
.env.local

# Local-only overrides (e.g. machine-specific config) are ignored by convention.
# Exception: the Backstage overlay's app-config.local.yaml is a tracked source
# (applied by `make backstage-sync`), so it's explicitly un-ignored below.
*.local.yaml
!platform/backstage/overlay/files/app-config.local.yaml

# Python
__pycache__/
*.pyc
.venv/

# Claude AI
.claude

# Go binaries
services/incident-generator/incident-generator